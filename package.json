{
  "name": "chatto-js",
  "version": "0.4.0",
  "description": "TypeScript client for the Chatto chat server",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maradotwebp/chatto.js.git"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./gen/*": {
      "types": "./dist/gen/*.d.ts",
      "import": "./dist/gen/*.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "generate": "bun scripts/generate.ts",
    "release": "bun run build && changeset publish",
    "sync-protos": "bun scripts/sync-protos.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.10.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.61.0",
    "@bufbuild/protoc-gen-es": "^2.10.0",
    "@changesets/cli": "^2.31.1",
    "@types/bun": "^1.3.14",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "chatto",
    "connectrpc",
    "protobuf",
    "websocket"
  ]
}
